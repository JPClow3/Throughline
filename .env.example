# ---------------------------------------------------------------------------
# Deployment environment for the Dokploy compose stack (docker-compose.yml).
# Copy to `.env` and fill in. Do NOT commit the real .env.
# ---------------------------------------------------------------------------

# Public hostname Traefik routes to (web at /, push-api at /api).
# Use a real domain in production — push notifications / PWA require HTTPS.
APP_HOST=todo.example.com

# --- VAPID keys (Web Push) --------------------------------------------------
# Generate once:  npm run vapid -w apps/push-api
# The PUBLIC key is used in BOTH places below (server signs, browser subscribes).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Baked into the web bundle at build time so users don't have to paste it in
# Settings. Must equal VAPID_PUBLIC_KEY above.
VITE_VAPID_PUBLIC_KEY=

# --- Accounts + encrypted sync ---------------------------------------------
# Signs session cookies. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# --- Hardening (recommended) ------------------------------------------------
# When set, POST /dispatch-due requires `Authorization: Bearer <token>`.
# ofelia passes this automatically. Generate any long random string.
DISPATCH_TOKEN=

# When set, CORS is restricted to this origin instead of allowing all.
# For same-origin /api this can be left blank, or set to https://APP_HOST.
CORS_ORIGIN=

# Max push-API requests per IP per minute (rate limiting). Default 120.
RATE_LIMIT_MAX=120

# --- Traefik (Dokploy defaults; override only if your setup differs) --------
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
