{
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "${description}",
      "isSubtle": true,
      "wrap": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "$data": "${tasks}",
          "title": "${status}",
          "value": "${name}"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Throughline",
      "url": "web+throughline://today"
    }
  ]
}
